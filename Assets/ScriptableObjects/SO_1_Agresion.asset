  m_Script: {fileID: 11500000, guid: 7ae2062fed6783447a50a736ff97a758, type: 3}
  m_Name: SO_1_Agresion
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  npcText: "\xA1Llevo tres d\xEDas tragando polvo radioactivo all\xE1 afuera! \xA1\xC1breme
    esa puerta trasera y dame raciones enteras AHORA, o te juro que entro por la
    fuerza!"
  tiempoLimite: 20
  choices:
  - choiceText: "Tranquilo, baja el tubo de metal. Est\xE1s a salvo aqu\xED. D\xE9jame
      revisar la bit\xE1cora y vemos qu\xE9 puedo darte."
    confianzaChange: 5
    estresChange: 1
    puntosChange: 5
    nextNode: {fileID: 11400000, guid: 203da11a07b5b9bad81beb42bca59ed0, type: 2}
  - choiceText: "Da un paso m\xE1s y activo la alarma perimetral. T\xFA no mandas
      aqu\xED, te formas como todos los dem\xE1s."
    confianzaChange: -5
    estresChange: 10
    puntosChange: 2
    nextNode: {fileID: 11400000, guid: cbc14c05ba3dca5c3bbe7dbd3105ae3c, type: 2}
  - choiceText: "No tengo raciones enteras, pero si me das esa bater\xEDa que traes
      en la mochila, te doy doble raci\xF3n de agua y barras energ\xE9ticas."
    confianzaChange: 2
    estresChange: 5
    puntosChange: 3
    nextNode: {fileID: 11400000, guid: adaa27e8197ecf429b0842bf69fdf496, type: 2}
